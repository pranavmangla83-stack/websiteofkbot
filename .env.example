PORT=4000
HOST=0.0.0.0
NODE_ENV=production
PG_POOL_MAX=3
PDF_PROCESSING_CONCURRENCY=1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/your_database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_ANON_KEY=your_legacy_supabase_anon_key_optional
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_SERVICE_ROLE_KEY=your_legacy_supabase_service_role_key_fallback
OPENAI_API_KEY=your_openai_api_key
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
ADMIN_EMAILS=founder@example.com
SUPPORT_EMAIL=support@example.com
RESEND_API_KEY=your_resend_api_key_optional
NOTIFICATION_FROM_EMAIL="Custom AI Chatbot <noreply@customaichatbot.online>"

KINDE_ISSUER_URL=https://your-domain.kinde.com
# Must match assets/js/kinde-config.js audience.
KINDE_AUDIENCE=https://your-domain.kinde.com/api
KINDE_CLIENT_ID=your_kinde_client_id
KINDE_CLIENT_SECRET=your_kinde_client_secret

# Use separate Razorpay key pairs, plan IDs, and webhook secrets for test and live.
RAZORPAY_MODE=live
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Create this monthly INR 350 Basic plan in Razorpay Dashboard and paste its plan id here.
RAZORPAY_BASIC_PLAN_ID=plan_xxxxxxxxxx

# Create this monthly INR 500 Pro plan in Razorpay Dashboard and paste its plan id here.
RAZORPAY_PRO_PLAN_ID=plan_yyyyyyyyyy
